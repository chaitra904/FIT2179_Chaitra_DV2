{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 390,
  "padding": 8,
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    }
  },
  "data": {
    "values": [
      {
        "factor": "Diabetes",
        "low_value": 0.6462,
        "high_value": 0.6633,
        "delta_pct": 2.6478
      },
      {
        "factor": "Cholesterol",
        "low_value": 258.7089,
        "high_value": 261.9704,
        "delta_pct": 1.2607
      },
      {
        "factor": "Systolic blood pressure",
        "low_value": 134.7098,
        "high_value": 135.7311,
        "delta_pct": 0.7582
      },
      {
        "factor": "BMI",
        "low_value": 28.8914,
        "high_value": 28.8916,
        "delta_pct": 0.0009
      },
      {
        "factor": "Smoking",
        "low_value": 0.8978,
        "high_value": 0.8952,
        "delta_pct": -0.2863
      },
      {
        "factor": "Stress",
        "low_value": 5.4785,
        "high_value": 5.4540,
        "delta_pct": -0.4475
      }
    ]
  },
  "transform": [
    {
      "calculate": "abs(datum.delta_pct)",
      "as": "abs_delta"
    },
    {
      "calculate": "(datum.delta_pct >= 0 ? '+' : '') + format(datum.delta_pct, '.1f') + '%'",
      "as": "delta_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [5, 4],
        "strokeWidth": 1.4,
        "color": "#d7a3b4"
      },
      "encoding": {
        "x": {
          "datum": 0
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 8
      },
      "encoding": {
        "y": {
          "field": "factor",
          "type": "nominal",
          "sort": {
            "field": "abs_delta",
            "order": "descending"
          }
        },
        "x": {
          "field": "delta_pct",
          "type": "quantitative",
          "title": "Higher-risk patients relative to lower-risk patients (%)",
          "scale": {
            "domain": [-1, 3]
          }
        },
        "color": {
          "condition": {
            "test": "datum.delta_pct >= 0",
            "value": "#7b2d4d"
          },
          "value": "#e1a1b4"
        },
        "tooltip": [
          {
            "field": "factor",
            "title": "Risk factor"
          },
          {
            "field": "low_value",
            "title": "Lower-risk mean",
            "format": ".2f"
          },
          {
            "field": "high_value",
            "title": "Higher-risk mean",
            "format": ".2f"
          },
          {
            "field": "delta_pct",
            "title": "Relative difference",
            "format": "+.2f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.delta_pct >= 0"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#5e2740"
      },
      "encoding": {
        "y": {
          "field": "factor",
          "type": "nominal",
          "sort": {
            "field": "abs_delta",
            "order": "descending"
          }
        },
        "x": {
          "field": "delta_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "delta_label"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.delta_pct < 0"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#5e2740"
      },
      "encoding": {
        "y": {
          "field": "factor",
          "type": "nominal",
          "sort": {
            "field": "abs_delta",
            "order": "descending"
          }
        },
        "x": {
          "field": "delta_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "delta_label"
        }
      }
    }
  ]
}
